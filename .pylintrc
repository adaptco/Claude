[MASTER]
jobs = 1

[MESSAGES CONTROL]
# too-few-public-methods: test mock/helper classes are intentionally thin.
# missing-module-docstring: module-level docstrings are present in source files.
disable =
    too-few-public-methods,
    missing-module-docstring

[FORMAT]
max-line-length = 100

[SIMILARITIES]
min-similarity-lines = 10
