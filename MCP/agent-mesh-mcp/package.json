{
  "name": "agent-mesh-mcp",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev --parallel",
    "test": "turbo test",
    "lint": "turbo lint",
    "hello-mesh": "tsx apps/gateway/src/hello-mesh.ts",
    "mcp:serve": "pnpm --filter @agent-mesh/mcp-server serve",
    "sidecar:serve": "python services/digital-twin-sidecar/app.py",
    "dev:hybrid": "concurrently -k -n MCP,SIDECAR -c cyan,green \"pnpm mcp:serve\" \"pnpm sidecar:serve\""
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "concurrently": "^9.0.1",
    "turbo": "^2.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.5.0"
  }
}
